@article{troncoso_decentralized_2020,
	title = {Decentralized {Privacy}-{Preserving} {Proximity} {Tracing}},
	copyright = {Creative Commons Attribution 4.0 International},
	url = {https://arxiv.org/abs/2005.12273},
	doi = {10.48550/ARXIV.2005.12273},
	abstract = {This document describes and analyzes a system for secure and privacy-preserving proximity tracing at large scale. This system, referred to as DP3T, provides a technological foundation to help slow the spread of SARS-CoV-2 by simplifying and accelerating the process of notifying people who might have been exposed to the virus so that they can take appropriate measures to break its transmission chain. The system aims to minimise privacy and security risks for individuals and communities and guarantee the highest level of data protection. The goal of our proximity tracing system is to determine who has been in close physical proximity to a COVID-19 positive person and thus exposed to the virus, without revealing the contact's identity or where the contact occurred. To achieve this goal, users run a smartphone app that continually broadcasts an ephemeral, pseudo-random ID representing the user's phone and also records the pseudo-random IDs observed from smartphones in close proximity. When a patient is diagnosed with COVID-19, she can upload pseudo-random IDs previously broadcast from her phone to a central server. Prior to the upload, all data remains exclusively on the user's phone. Other users' apps can use data from the server to locally estimate whether the device's owner was exposed to the virus through close-range physical proximity to a COVID-19 positive person who has uploaded their data. In case the app detects a high risk, it will inform the user.},
	urldate = {2025-09-01},
	journal = {arXiv},
	author = {Troncoso, Carmela and Payer, Mathias and Hubaux, Jean-Pierre and Salathé, Marcel and Larus, James and Bugnion, Edouard and Lueks, Wouter and Stadler, Theresa and Pyrgelis, Apostolos and Antonioli, Daniele and Barman, Ludovic and Chatel, Sylvain and Paterson, Kenneth and Čapkun, Srdjan and Basin, David and Beutel, Jan and Jackson, Dennis and Roeschlin, Marc and Leu, Patrick and Preneel, Bart and Smart, Nigel and Abidin, Aysajan and Gürses, Seda and Veale, Michael and Cremers, Cas and Backes, Michael and Tippenhauer, Nils Ole and Binns, Reuben and Cattuto, Ciro and Barrat, Alain and Fiore, Dario and Barbosa, Manuel and Oliveira, Rui and Pereira, José},
	year = {2020},
	note = {Version Number: 1},
	keywords = {FOS: Computer and information sciences, Computers and Society (cs.CY), Cryptography and Security (cs.CR)},
}

@article{richards_crossborder_2009,
	title = {Cross‐border malaria control for internally displaced persons: observational results from a pilot programme in eastern {Burma}/{Myanmar}},
	volume = {14},
	copyright = {http://onlinelibrary.wiley.com/termsAndConditions\#vor},
	issn = {1360-2276, 1365-3156},
	shorttitle = {Cross‐border malaria control for internally displaced persons},
	url = {https://onlinelibrary.wiley.com/doi/10.1111/j.1365-3156.2009.02258.x},
	doi = {10.1111/j.1365-3156.2009.02258.x},
	abstract = {Summary
            
              Objectives 
              To document the feasibility of a cross‐border community based integrated malaria control programme implemented by internally displaced persons in eastern Burma/Myanmar.
            
            
              Methods 
              This pilot study was conducted from February 2003 through January 2005 in seven villages of displaced ethnic Karen. Interventions comprised early diagnosis of
              Plasmodium falciparum
              and treatment with mefloquine and artesunate, distribution of long‐lasting insecticide treated nets (LLITNs), and educational messages. The primary outcome measure was
              P. falciparum
              prevalence during bi‐annual universal screenings with the Paracheck‐Pf
              ®
              (Orchid Biomedical Systems, Goa, India) device. Secondary outcomes were
              P. falciparum
              incidence and process indicators related to net use and malaria knowledge, attitudes and practices (KAP).
            
            
              Results 
              P. falciparum
              prevalence in original programme areas declined from 8.4\% [95\% confidence interval (CI) 8.3–8.6] at baseline to 1.1\% (95\% CI 1.1–1.2) in the final screening. Annual incidence in original areas declined from 232 to 70 cases/1000/year [incidence rate ratio 0.30 (95\% CI 0.24–0.39)]. The proportion of household members sleeping under a LLITN improved from 0\% to 89\% and malaria KAP improved in all areas.
            
            
              Conclusions 
              Integrated malaria control organized and implemented by displaced persons is feasible in eastern Burma/Myanmar. The decline in
              P. falciparum
              prevalence and incidence suggest that it may be possible to reduce the burden of disease and the reservoir of malaria in eastern Burma/Myanmar, with implications for malaria control in the greater Mekong region.
            
          , 
            
              
              
                Objectifs: 
                Documenter la faisabilité d’un programme intégré transfrontalier basé sur la communauté, de lutte contre la malaria, mis en œuvre par les personnes déplacées dans l’est de la Birmanie/du Myanmar.
              
              
                Méthodes: 
                Cette étude pilote a été menée de février 2003 à janvier 2005 dans 7 villages de l’ethnie déplacée Karen. Les interventions comprenaient un diagnostic précoce de
                Plasmodium falciparum
                et le traitement par l’artésunate et la méfloquine, la distribution de moustiquaires imprégnées d’insecticides durables (MID), et des messages d’éducation. Le résultat principal a été de mesurer la prévalence de
                P. falciparum
                au cours d’un screening universel bi‐annuel avec le dispositif Paracheck‐Pf
                ®
                . Les résultats secondaires consistaient en l’incidence de
                P. falciparum
                et les indicateurs de processus liés à l’utilisation de moustiquaires ainsi que les attitudes, pratiques et connaissances (APC) sur la malaria,.
              
              
                Résultats: 
                La prévalence de
                P. falciparum
                dans les régions du programme original a baissé de 8,4\% (IC95\%: 8,3–8,6) à la ligne de base à 1,1\% (IC95\%: 1,1–1,2) lors du dernier screening. L’incidence annuelle dans les zones originales a diminué, passant de 232 à 70 cas/1000/an [IRR : 0,30 (CI95\%: 0,24–0,39)]. La proportion des membres de la famille dormant sous MID a connu une amélioration allant de 0\%à 89\% et les APC sur la malaria se sont améliorées dans toutes les zones.
              
              
                Conclusions: 
                Le contrôle intégré de la malaria, organisé et mis en œuvre par les personnes déplacées est réalisable dans l’est de la Birmanie/du Myanmar. La baisse de la prévalence et de l’incidence de
                P. falciparum
                suggèrent qu’il est possible de réduire la charge de la maladie et le réservoir de la malaria dans l’est de la Birmanie/du Myanmar, avec des implications sur le contrôle de la malaria dans la région étendue du Mékong.
              
            
          , 
            
              
              
                Objetivos: 
                Documentar la factibilidad de un programa integrado de control de malaria basado en la comunidad a través de la frontera, implementado por población internamente desplazada en Birmania del Este / Myanmar.
              
              
                Métodos: 
                Este estudio piloto se condujo entre Febrero del 2003 y Enero del 2005 en 7 poblados de desplazados de la etnia Karen. Las intervenciones incluían el diagnóstico precoz de infección por
                Plasmodium falciparum
                y el tratamiento con mefloquina y artesunato, distribución de redes mosquiteras impregnadas de larga duración, y mensajes educativos. El resultado primario a medir fue prevalencia de
                P. falciparum
                durante los tamizajes universales bianuales utilizando el Paracheck‐Pf®
              
              
                Los resultados secundarios fueron incidencia de
                P. falciparum
                e indicadores de procesos relacionados con el uso de las mosquiteras y conocimientos, actitud y práctica (CAP) de malaria.
              
              
                Resultados: 
                La prevalencia de
                P. falciparum
                en las áreas originales del programa declinó del 8.4\% (95\% IC 8.3–8.6) al comienzo del estudio a 1.1\% (95\% IC 1.1–1.2) al final del tamizaje. La incidencia anual en las áreas originales declinó de 232 a 70 casos/1,000/año [IRR 0.30 (95\% IC 0.24–0.39)]. La proporción de miembros en los hogares durmiendo bajo redes mosquiteras mejoró de 0\% a 89\% y el CAP de malaria mejoró en todas las áreas.
              
              
                Conclusiones: 
                El control integrado de la malaria organizado e implementado por personas desplazadas es posible en Birmania del este / Myanmar. La disminución en la prevalencia e incidencia de
                P. falciparum
                sugiere que es posible reducir la carga de enfermedad y el reservorio de malaria en Birmania del este/Myanmar, con implicaciones para el control de la malaria en la región de Mekong.},
	language = {en},
	number = {5},
	urldate = {2025-09-13},
	journal = {Tropical Medicine \& International Health},
	author = {Richards, Adam K. and Banek, Kristin and Mullany, Luke C and Lee, Catherine I. and Smith, Linda and Oo, Eh Kalu Shwe and Lee, Thomas J.},
	month = may,
	year = {2009},
	pages = {512--521},
}

