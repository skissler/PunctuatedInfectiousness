@article{feleke_plasmodium_2021,
	title = {Plasmodium falciparum is evolving to escape malaria rapid diagnostic tests in {Ethiopia}},
	volume = {6},
	issn = {2058-5276},
	url = {https://www.nature.com/articles/s41564-021-00962-4},
	doi = {10.1038/s41564-021-00962-4},
	abstract = {Abstract
            
              In Africa, most rapid diagnostic tests (RDTs) for falciparum malaria recognize histidine-rich protein 2 antigen.
              Plasmodium falciparum
              parasites lacking histidine-rich protein 2 (
              pfhrp2
              ) and 3 (
              pfhrp3
              ) genes escape detection by these RDTs, but it is not known whether these deletions confer sufficient selective advantage to drive rapid population expansion. By studying blood samples from a cohort of 12,572 participants enroled in a prospective, cross-sectional survey along Ethiopia’s borders with Eritrea, Sudan and South Sudan using RDTs, PCR, an ultrasensitive bead-based immunoassay for antigen detection and next-generation sequencing, we estimate that histidine-rich protein 2-based RDTs would miss 9.7\% (95\% confidence interval 8.5–11.1) of
              P. falciparum
              malaria cases owing to
              pfhrp2
              deletion. We applied a molecular inversion probe-targeted deep sequencing approach to identify distinct subtelomeric deletion patterns and well-established
              pfhrp3
              deletions and to uncover recent expansion of a singular
              pfhrp2
              deletion in all regions sampled. We propose a model in which
              pfhrp3
              deletions have arisen independently multiple times, followed by strong positive selection for
              pfhrp2
              deletion owing to RDT-based test-and-treatment. Existing diagnostic strategies need to be urgently reconsidered in Ethiopia, and improved surveillance for
              pfhrp2
              deletion is needed throughout the Horn of Africa.},
	language = {en},
	number = {10},
	urldate = {2025-09-01},
	journal = {Nature Microbiology},
	author = {Feleke, Sindew M. and Reichert, Emily N. and Mohammed, Hussein and Brhane, Bokretsion G. and Mekete, Kalkidan and Mamo, Hassen and Petros, Beyene and Solomon, Hiwot and Abate, Ebba and Hennelly, Chris and Denton, Madeline and Keeler, Corinna and Hathaway, Nicholas J. and Juliano, Jonathan J. and Bailey, Jeffrey A. and Rogier, Eric and Cunningham, Jane and Aydemir, Ozkan and Parr, Jonathan B.},
	month = sep,
	year = {2021},
	pages = {1289--1299},
	file = {Full Text:/Users/stephen_ally/Zotero/storage/RGCDMD2C/Feleke et al. - 2021 - Plasmodium falciparum is evolving to escape malari.pdf:application/pdf},
}

