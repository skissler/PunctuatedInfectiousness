	year = {2024},
	note = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1111/irv.13342},
	keywords = {vaccine effectiveness, influenza, vaccination},
	pages = {e13342},
	file = {Full Text PDF:/Users/stephen_ally/Zotero/storage/EEPWUPTD/Chung et al. - 2024 - Late-Season Influenza Vaccine Effectiveness Agains.pdf:application/pdf;Snapshot:/Users/stephen_ally/Zotero/storage/8ZCJJN9C/irv.html:text/html},
