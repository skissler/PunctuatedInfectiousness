Cell[BoxData[
 RowBox[{
  RowBox[{"steps", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"pwgen", "[", 
      RowBox[{
       RowBox[{"#", "[", 
        RowBox[{"[", "1", "]"}], "]"}], ",", " ", 
       RowBox[{"#", "[", 
        RowBox[{"[", "2", "]"}], "]"}]}], "]"}], "&"}], "/@", 
    RowBox[{"(", 
     RowBox[{
