Cell[BoxData[{
 RowBox[{
  RowBox[{"n", " ", "=", " ", "20"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"latentdraws", " ", "=", " ", 
   RowBox[{"RandomVariate", "[", 
    RowBox[{
     RowBox[{"ExponentialDistribution", "[", 
      RowBox[{"1", "/", "2"}], "]"}], ",", " ", "n"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"infectiousdraws", " ", "=", " ", 
   RowBox[{"RandomVariate", "[", 
    RowBox[{
     RowBox[{"ExponentialDistribution", "[", 
      RowBox[{"1", "/", "2"}], "]"}], ",", " ", "n"}], "]"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.985088751309641*^9, 3.9850888096492023`*^9}, {
  3.98508941074194*^9, 3.985089411560952*^9}, {3.9850898326787233`*^9, 
