     RowBox[{"Filling", "->", "Axis"}], ",", " ", 
     RowBox[{"FillingStyle", "->", 
      RowBox[{"{", 
       RowBox[{"Purple", ",", " ", 
        RowBox[{"Opacity", "[", "0.1", "]"}]}], "}"}]}]}], "]"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"steps", "[", 
        RowBox[{"[", "1", "]"}], "]"}], ",", 
