 CellLabel->
  "In[155]:=",ExpressionUUID->"8109315e-9a89-4a0f-a6e1-e9e9c21663b1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"pwgen", "[", 
   RowBox[{"latent_", ",", " ", "infectious_"}], "]"}], ":=", 
  RowBox[{"Piecewise", "[", "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", " ", 
       RowBox[{"x", "\[LessEqual]", "latent"}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"0.15", " ", "+", " ", 
        RowBox[{"0.002", "*", 
         RowBox[{"RandomReal", "[", "1", "]"}]}]}], ",", " ", 
       RowBox[{
        RowBox[{"x", ">", "latent"}], " ", "&&", " ", 
        RowBox[{"x", "\[LessEqual]", " ", 
         RowBox[{"latent", "+", "infectious"}]}]}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"0", ",", " ", 
       RowBox[{"x", ">", 
        RowBox[{"latent", "+", "infectious"}]}]}], "}"}]}], "}"}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.985089454342149*^9, 3.985089666835433*^9}, 
   3.9850897880969152`*^9, {3.98509014212626*^9, 3.9850901821511583`*^9}, {
   3.985090279979176*^9, 3.985090299001926*^9}, {3.985090388945622*^9, 
