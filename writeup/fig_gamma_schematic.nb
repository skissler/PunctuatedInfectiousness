  3.9850901155935783`*^9, 3.985090132392148*^9}, {3.9850903140464487`*^9, 
  3.985090314225926*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"8109315e-9a89-4a0f-a6e1-e9e9c21663b1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"pwgen", "[", 
   RowBox[{"latent_", ",", " ", "infectious_"}], "]"}], ":=", 
  RowBox[{"Piecewise", "[", "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", " ", 
       RowBox[{"x", "\[LessEqual]", "latent"}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"0.15", " ", "+", " ", 
        RowBox[{"0.002", "*", 
         RowBox[{"RandomReal", "[", "1", "]"}]}]}], ",", " ", 
       RowBox[{
        RowBox[{"x", ">", "latent"}], " ", "&&", " ", 
        RowBox[{"x", "\[LessEqual]", " ", 
         RowBox[{"latent", "+", "infectious"}]}]}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"0", ",", " ", 
       RowBox[{"x", ">", 
        RowBox[{"latent", "+", "infectious"}]}]}], "}"}]}], "}"}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.985089454342149*^9, 3.985089666835433*^9}, 
   3.9850897880969152`*^9, {3.98509014212626*^9, 3.9850901821511583`*^9}, {
   3.985090279979176*^9, 3.985090299001926*^9}, {3.985090388945622*^9, 
   3.985090388995434*^9}, {3.985090847616576*^9, 3.985090863651335*^9}},
 CellLabel->"In[5]:=",ExpressionUUID->"409e83f7-ae5c-4fa8-8aff-c4e9a6e8b254"],

Cell[BoxData[
 RowBox[{
  RowBox[{"steps", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"pwgen", "[", 
      RowBox[{
       RowBox[{"#", "[", 
        RowBox[{"[", "1", "]"}], "]"}], ",", " ", 
       RowBox[{"#", "[", 
        RowBox[{"[", "2", "]"}], "]"}]}], "]"}], "&"}], "/@", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"latentdraws", ",", " ", "infectiousdraws"}], "}"}], 
