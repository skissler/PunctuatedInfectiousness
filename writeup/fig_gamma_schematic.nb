Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "36", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"latentdraws", " ", "=", " ", 
   RowBox[{"RandomVariate", "[", 
    RowBox[{
     RowBox[{"ExponentialDistribution", "[", "\[Gamma]", "]"}], ",", " ", 
     "n"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"infectiousdraws", " ", "=", " ", 
   RowBox[{"RandomVariate", "[", 
    RowBox[{
     RowBox[{"ExponentialDistribution", "[", "\[Alpha]", "]"}], ",", " ", 
     "n"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"pwgen", "[", 
   RowBox[{"latent_", ",", " ", "infectious_"}], "]"}], ":=", 
  RowBox[{"Piecewise", "[", "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", " ", 
       RowBox[{"x", "\[LessEqual]", "latent"}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Beta]", "+", " ", 
        RowBox[{
         RowBox[{"\[Beta]", "/", "100"}], "*", 
         RowBox[{"RandomReal", "[", "1", "]"}]}]}], ",", " ", 
       RowBox[{
        RowBox[{"x", ">", "latent"}], " ", "&&", " ", 
        RowBox[{"x", "\[LessEqual]", " ", 
         RowBox[{"latent", "+", "infectious"}]}]}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"0", ",", " ", 
       RowBox[{"x", ">", 
        RowBox[{"latent", "+", "infectious"}]}]}], "}"}]}], "}"}], 
   "\[IndentingNewLine]", "]"}]}], "\n", 
 RowBox[{
  RowBox[{"steps", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"pwgen", "[", 
      RowBox[{
       RowBox[{"#", "[", 
        RowBox[{"[", "1", "]"}], "]"}], ",", " ", 
       RowBox[{"#", "[", 
        RowBox[{"[", "2", "]"}], "]"}]}], "]"}], "&"}], "/@", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"latentdraws", ",", " ", "infectiousdraws"}], "}"}], 
      "\[Transpose]"}], ")"}]}]}], ";"}], "\n", 
 RowBox[{"Show", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{"steps", ",", 
