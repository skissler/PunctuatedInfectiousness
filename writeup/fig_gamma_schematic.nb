Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "2", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"spikedraws", " ", "=", " ", 
   RowBox[{
    RowBox[{"RandomVariate", "[", 
     RowBox[{
      RowBox[{"ExponentialDistribution", "[", "\[Gamma]", "]"}], ",", "n"}], 
     "]"}], " ", "+", " ", 
    RowBox[{"RandomVariate", "[", 
     RowBox[{
      RowBox[{"ExponentialDistribution", "[", "\[Alpha]", "]"}], ",", "n"}], 
     "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"makearrows", "[", "xval_", "]"}], ":=", 
  RowBox[{"Arrow", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"xval", ",", " ", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"xval", ",", " ", "\[Beta]"}], "}"}]}], "}"}], "]"}]}], "\n", 
 RowBox[{"Show", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"A", "[", "\[Tau]", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Tau]", ",", "0", ",", "14"}], "}"}], ",", " ", 
     RowBox[{"PlotRange", "->", 
      RowBox[{"{", 
       RowBox[{"0", ",", "\[Beta]"}], "}"}]}], ",", " ", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"{", 
       RowBox[{"{", 
        RowBox[{"Black", ",", 
         RowBox[{"Thickness", "[", "0.015", "]"}]}], "}"}], "}"}]}]}], "]"}], 
   ",", "\[IndentingNewLine]", 
   RowBox[{"Graphics", "[", 
    RowBox[{"{", 
     RowBox[{"Purple", ",", " ", 
      RowBox[{"Opacity", "[", "0.8", "]"}], ",", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"makearrows", "[", "#", "]"}], "&"}], "/@", "spikedraws"}]}], 
     "}"}], "]"}]}], "]"}]}], "Input",
